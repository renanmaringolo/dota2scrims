<h2>Scrim Cancelada pelo Manager</h2>

<p>Uma scrim foi cancelada por um manager.</p>

<table>
  <tr>
    <td><strong>Data/Hora:</strong></td>
    <td><%= @formatted_time %></td>
  </tr>
  <tr>
    <td><strong>Time:</strong></td>
    <td><%= @team.name %></td>
  </tr>
  <tr>
    <td><strong>Manager:</strong></td>
    <td><%= @team.manager_name %> (<%= @team.manager_email %>)</td>
  </tr>
  <tr>
    <td><strong>Motivo:</strong></td>
    <td><%= @reason %></td>
  </tr>
</table>
