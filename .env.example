# Docker Compose environment variables
# Copy this file to .env and fill in real values

# PostgreSQL
POSTGRES_USER=dota2scrims
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=dota2scrims_dev

# JWT signing secret (use: openssl rand -hex 64)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-64

# Seed password for dev users (optional, generates random if not set)
SEED_PASSWORD=change-me
